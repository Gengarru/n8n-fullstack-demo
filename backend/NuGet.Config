<?xml version="1.0" encoding="utf-8"?>
<!--
  Pinned intentionally for reproducibility: without this file, restore falls
  back to whatever package sources are configured in the machine's global
  NuGet.Config, which can include private/corporate feeds that outside
  contributors (or CI) won't have access to. Clearing sources and pinning to
  nuget.org only means this repo builds identically on any machine.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
